    "openai": "^6.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.6",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.6",
    "tmdb-ts": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.3",
